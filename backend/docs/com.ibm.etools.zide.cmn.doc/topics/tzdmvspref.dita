<shortdesc>Use the <wintitle>MVS Files</wintitle> page to set preferences
for the <uicontrol>MVS Files</uicontrol> subsystem in the <wintitle>Remote
Systems</wintitle> view.</shortdesc>
<prolog><metadata>
<keywords><indexterm>preferences<indexterm>MVS files</indexterm></indexterm>
</keywords>
<keywords><indexterm>MVS Files<indexterm>preferences</indexterm></indexterm>
</keywords>
