<li><xref format="html" href="../../com.ibm.etools.getstart.wsentdev.doc/topics/quicktasksbycomponent.html#quick_zide" scope="peer">Quick tasks for zIDE</xref></li>
<li><xref href="tzdcmn043.dita" type="task" /></li>
<li><xref href="tzdnewsubproject.dita" type="task" /></li>
<li><xref href="../../com.ibm.uss.projects.doc/topics/creatinganewtpfproject_t.dita" type="task" /></li>
