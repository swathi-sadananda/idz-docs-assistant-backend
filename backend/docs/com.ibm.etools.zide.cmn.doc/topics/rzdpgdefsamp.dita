<section><codeblock>&lt;?xml version="1.0" encoding="UTF-8"?>
&lt;DEFAULT-VALUES>
  &lt;CATEGORY-INSTANCE>
    &lt;CATEGORY>COBOL_SETTINGS&lt;/CATEGORY>
    &lt;PROPERTY>
      &lt;NAME>HOST_COMPILE_OPTIONS&lt;/NAME>
      &lt;VALUE>TEST&lt;/VALUE>
    &lt;/PROPERTY>
    &lt;PROPERTY>
      &lt;NAME>COMPILE_JCL_PROCEDURE_NAME&lt;/NAME>
      &lt;VALUE>ELAXFCOC&lt;/VALUE>
    &lt;/PROPERTY>
  &lt;/CATEGORY-INSTANCE>
&lt;/DEFAULT-VALUES>
</codeblock></section>
