<title>Sample default values file</title><?Pub Caret -2?>
<shortdesc>This example illustrates a default values file.</shortdesc>
<prolog><metadata>
<keywords><indexterm>property groups<indexterm>default values example</indexterm></indexterm>
<indexterm>default values example</indexterm><indexterm>configuring
property groups<indexterm>default values example</indexterm></indexterm>
</keywords>
</metadata></prolog>
