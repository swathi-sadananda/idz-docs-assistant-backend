<task id="AllocateVSAM" xml:lang="en-us">
<title>Allocating VSAM data sets</title>
<!--<titlealts><navtitle></navtitle><searchtitle></searchtitle></titlealts>-->
<shortdesc>Use the <wintitle>Allocate VSAM Data Set</wintitle> wizard
to allocate VSAM data sets in the <wintitle>Remote  Systems</wintitle> view.</shortdesc>
<prolog><metadata>
<keywords><indexterm>allocate VSAM data set</indexterm><indexterm>VSAM
data set<indexterm>allocate</indexterm></indexterm></keywords>
</metadata></prolog>
<taskbody>
